<ui:UiPage x:Class="Bloxstrap.UI.Elements.Settings.Pages.AccountManagerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:models="clr-namespace:Bloxstrap.UI.ViewModels.Settings"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:Bloxstrap.UI.Elements.Controls"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="800"
      Title="AccountManagerPage"
      Scrollable="True">
    <StackPanel Margin="0,0,14,14">
        <TextBlock Margin="0,0,0,8" Text="Manage multiple Roblox accounts. Save, switch, and remove accounts securely." FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

        <ui:InfoBar Margin="0,0,0,16" Padding="8" Title="Security" Message="Account cookies are encrypted using Windows DPAPI and can only be decrypted on this user account on this machine. Cookie access must be enabled in Behaviour settings." Severity="Informational" IsOpen="True" IsClosable="False" />

        <!-- Action buttons -->
        <WrapPanel Margin="0,0,0,8">
            <ui:Button Margin="0,0,8,8" Content="Add Current Account" Appearance="Primary" Command="{Binding AddCurrentAccountCommand}" />
            <ui:Button Margin="0,0,8,8" Content="Switch To Selected" Appearance="Success" Command="{Binding SwitchAccountCommand}" IsEnabled="{Binding HasSelection}" />
            <ui:Button Margin="0,0,8,8" Content="Refresh Info" Appearance="Info" Command="{Binding RefreshAccountCommand}" IsEnabled="{Binding HasSelection}" />
            <ui:Button Margin="0,0,8,8" Content="Edit Nickname" Appearance="Secondary" Command="{Binding EditNicknameCommand}" IsEnabled="{Binding HasSelection}" />
            <ui:Button Margin="0,0,8,8" Content="Remove Selected" Appearance="Danger" Command="{Binding RemoveAccountCommand}" IsEnabled="{Binding HasSelection}" />
            <ui:Button Margin="0,0,8,8" Content="Clear All" Appearance="Danger" Command="{Binding ClearAllAccountsCommand}" />
        </WrapPanel>

        <!-- Account count -->
        <TextBlock Margin="0,0,0,8" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}">
            <TextBlock.Text>
                <Binding Path="AccountCount" StringFormat="{}Total accounts: {0}" />
            </TextBlock.Text>
        </TextBlock>

        <!-- Accounts list -->
        <TextBlock Text="Saved Accounts" FontSize="20" FontWeight="Medium" Margin="0,0,0,8" />

        <Border BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="0" MinHeight="200">
            <ListView ItemsSource="{Binding Accounts}" SelectedItem="{Binding SelectedAccount, Mode=TwoWay}" HorizontalContentAlignment="Stretch" Background="Transparent" BorderThickness="0">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="8,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ui:SymbolIcon Grid.Column="0" Symbol="Person24" FontSize="28" Margin="0,0,12,0" VerticalAlignment="Center" />

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontSize="14" FontWeight="SemiBold" Text="{Binding Username}" />
                                    <TextBlock FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource SystemAccentColorSecondaryBrush}" Text="{Binding Nickname}" />
                                </StackPanel>
                                <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0}  ·  ID: {1}">
                                            <Binding Path="DisplayName" />
                                            <Binding Path="UserId" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock FontSize="11" FontStyle="Italic" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="{Binding Notes}" />
                            </StackPanel>

                            <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="{Binding LastUsed, StringFormat='Last used: {0:g}'}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <TextBlock Margin="0,16,0,0" Text="How It Works" FontSize="16" FontWeight="Medium" />
        <TextBlock Margin="0,4,0,0" TextWrapping="Wrap" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="13" Text="1. Log into a Roblox account in Roblox Player or the website.&#x0a;2. Click 'Add Current Account' to save the session cookie.&#x0a;3. Repeat for each account you want to save.&#x0a;4. Select an account and click 'Switch To Selected' to activate it.&#x0a;5. Use 'Edit Nickname' to label accounts (e.g. 'Main', 'Alt').&#x0a;6. Use 'Refresh Info' to update username/display name from Roblox.&#x0a;&#x0a;Note: If Roblox logs you out or the cookie expires, you will need to re-add the account." />
    </StackPanel>
</ui:UiPage>
